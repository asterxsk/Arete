# Ignore everything by default
*

# Un-ignore specific root files
!.gitignore
!AGENTS.md
!README.md
!install.sh
!install.ps1
!LICENSE
!version.txt

# Un-ignore agent folder
!agent/

# Un-ignore specific files and folders inside agent/
!agent/keybindings.json
!agent/extensions/
!agent/themes/

# Un-ignore everything recursively inside extensions and themes
!agent/extensions/**
!agent/themes/**

# Re-ignore specific things inside extensions
agent/extensions/commandcode-provider/
agent/extensions/**/docs/
agent/extensions/**/doc/

# Explicitly ignore crash log (though * already ignores it, being explicit)
agent/pi-crash.log
