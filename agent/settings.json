    "freerouter/auto",
    "opencode/big-pickle",
    "commandcode/zai-org/GLM-5.2",
    "commandcode/xiaomi/mimo-v2.5",
    "commandcode/xiaomi/mimo-v2.5-pro",
    "commandcode/deepseek/deepseek-v4-pro",
    "commandcode/deepseek/deepseek-v4-flash"
